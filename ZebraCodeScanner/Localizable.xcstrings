    "settings.data.clear_history_message": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This will permanently delete all generated and scanned code history."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto eliminará permanentemente todo el historial de códigos generados y escaneados."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cela supprimera définitivement tout l'historique des codes générés et scannés."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dies löscht dauerhaft den gesamten Verlauf generierter und gescannter Codes."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questo eliminerà permanentemente tutta la cronologia dei codici generati e scansionati."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Isso excluirá permanentemente todo o histórico de códigos gerados e escaneados."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Это навсегда удалит всю историю созданных и отсканированных кодов."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Це назавжди видалить всю історію створених та відсканованих кодів."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Spowoduje to trwałe usunięcie całej historii wygenerowanych i zeskanowanych kodów."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Dit verwijdert permanent alle gegenereerde en gescande codegeschiedenis."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Detta raderar permanent all historik för genererade och skannade koder."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "生成およびスキャンしたすべてのコード履歴が完全に削除されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "생성 및 스캔한 모든 코드 기록이 영구적으로 삭제됩니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这将永久删除所有生成和扫描的码记录。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "這將永久刪除所有產生和掃描的碼紀錄。"
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "การดำเนินการนี้จะลบประวัติโค้ดที่สร้างและสแกนทั้งหมดอย่างถาวร"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "سيؤدي هذا إلى حذف جميع سجلات الرموز المنشأة والممسوحة نهائياً."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu işlem tüm oluşturulan ve taranan kod geçmişini kalıcı olarak silecektir."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "इससे सभी बनाए और स्कैन किए गए कोड का इतिहास स्थायी रूप से हट जाएगा।"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Thao tác này sẽ xóa vĩnh viễn tất cả lịch sử mã đã tạo và đã quét."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Ini akan menghapus semua riwayat kode yang dibuat dan dipindai secara permanen."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Ini akan memadamkan semua sejarah kod yang dijana dan diimbas secara kekal."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Dette vil permanent slette all historikk for genererte og skannede koder."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Dette vil permanent slette al historik for genererede og scannede koder."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tämä poistaa pysyvästi kaikkien luotujen ja skannattujen koodien historian."
          }
        },
        "uz": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu barcha yaratilgan va skanlangan kodlar tarixini butunlay o'chiradi."
          }
        }
      }
    },
