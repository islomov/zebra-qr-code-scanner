    "force_update.message": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A new version of the app is available.\nPlease update to continue using the app."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Hay una nueva versión de la app disponible.\nPor favor, actualiza para seguir usando la app."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Une nouvelle version de l'app est disponible.\nVeuillez mettre à jour pour continuer à utiliser l'app."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Eine neue Version der App ist verfügbar.\nBitte aktualisiere, um die App weiter nutzen zu können."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "È disponibile una nuova versione dell'app.\nAggiorna per continuare a usare l'app."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Uma nova versão do app está disponível.\nAtualize para continuar usando o app."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Доступна новая версия приложения.\nПожалуйста, обновите, чтобы продолжить использование."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Доступна нова версія додатку.\nБудь ласка, оновіть, щоб продовжити використання."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Dostępna jest nowa wersja aplikacji.\nProszę zaktualizować, aby kontynuować korzystanie."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Er is een nieuwe versie van de app beschikbaar.\nWerk bij om de app te blijven gebruiken."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "En ny version av appen är tillgänglig.\nVänligen uppdatera för att fortsätta använda appen."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アプリの新しいバージョンが利用可能です。\n引き続きご利用いただくにはアップデートしてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "새로운 버전의 앱을 사용할 수 있습니다.\n앱을 계속 사용하려면 업데이트해 주세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "有新版本可用。\n请更新以继续使用本应用。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "有新版本可用。\n請更新以繼續使用本應用程式。"
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "มีเวอร์ชันใหม่ของแอปพร้อมใช้งาน\nกรุณาอัปเดตเพื่อใช้งานแอปต่อไป"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يتوفر إصدار جديد من التطبيق.\nيرجى التحديث لمتابعة استخدام التطبيق."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Uygulamanın yeni bir sürümü mevcut.\nUygulamayı kullanmaya devam etmek için lütfen güncelleyin."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "ऐप का नया वर्शन उपलब्ध है।\nऐप का उपयोग जारी रखने के लिए कृपया अपडेट करें।"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Đã có phiên bản mới của ứng dụng.\nVui lòng cập nhật để tiếp tục sử dụng ứng dụng."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Versi baru aplikasi tersedia.\nSilakan perbarui untuk melanjutkan penggunaan aplikasi."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Versi baharu aplikasi tersedia.\nSila kemas kini untuk terus menggunakan aplikasi."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "En ny versjon av appen er tilgjengelig.\nVennligst oppdater for å fortsette å bruke appen."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "En ny version af appen er tilgængelig.\nOpdater venligst for at fortsætte med at bruge appen."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Sovelluksesta on saatavilla uusi versio.\nPäivitä jatkaaksesi sovelluksen käyttöä."
          }
        },
        "uz": {
          "stringUnit": {
            "state": "translated",
            "value": "Ilovaning yangi versiyasi mavjud.\nIlovadan foydalanishni davom ettirish uchun yangilang."
          }
        }
      }
    },
