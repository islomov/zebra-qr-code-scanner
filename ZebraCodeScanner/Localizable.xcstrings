    "preview.barcode_save_error": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Failed to save barcode. Please check photo library permissions."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Error al guardar el código de barras. Revisa los permisos de la biblioteca de fotos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Échec de l'enregistrement du code-barres. Veuillez vérifier les autorisations de la photothèque."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Barcode konnte nicht gespeichert werden. Bitte überprüfe die Zugriffsrechte für die Fotomediathek."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossibile salvare il codice a barre. Controlla i permessi della libreria foto."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Falha ao salvar o código de barras. Verifique as permissões da biblioteca de fotos."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Не удалось сохранить штрих-код. Проверьте разрешения для фотобиблиотеки."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Не вдалося зберегти штрих-код. Перевірте дозволи для фотобібліотеки."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Nie udało się zapisać kodu kreskowego. Sprawdź uprawnienia do biblioteki zdjęć."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Opslaan van streepjescode mislukt. Controleer de machtigingen voor de fotobibliotheek."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Det gick inte att spara streckkoden. Kontrollera behörigheterna för fotobiblioteket."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "バーコードの保存に失敗しました。フォトライブラリの権限を確認してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "바코드 저장에 실패했습니다. 사진 라이브러리 권한을 확인해 주세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "条形码保存失败。请检查相册访问权限。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "條碼儲存失敗。請檢查相簿存取權限。"
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "บันทึกบาร์โค้ดไม่สำเร็จ กรุณาตรวจสอบสิทธิ์การเข้าถึงคลังรูปภาพ"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "فشل حفظ الباركود. يرجى التحقق من أذونات مكتبة الصور."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Barkod kaydedilemedi. Lütfen fotoğraf kitaplığı izinlerini kontrol edin."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "बारकोड सेव करना विफल रहा। कृपया फ़ोटो लाइब्रेरी अनुमतियाँ जांचें।"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Lưu mã vạch thất bại. Vui lòng kiểm tra quyền truy cập thư viện ảnh."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Gagal menyimpan barcode. Silakan periksa izin pustaka foto."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Gagal menyimpan kod bar. Sila semak kebenaran pustaka foto."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Kunne ikke lagre strekkoden. Vennligst sjekk tillatelser for bildebiblioteket."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Kunne ikke gemme stregkoden. Kontroller venligst tilladelser til fotobiblioteket."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Viivakoodin tallennus epäonnistui. Tarkista kuvakirjaston käyttöoikeudet."
          }
        },
        "uz": {
