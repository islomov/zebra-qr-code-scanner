    "generate.request.message": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "If you need additional QR codes or barcodes, let us know!"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Si necesitas códigos QR o de barras adicionales, ¡dínoslo!"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Si vous avez besoin de codes QR ou de codes-barres supplémentaires, faites-le nous savoir !"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wenn du zusätzliche QR-Codes oder Barcodes benötigst, lass es uns wissen!"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Se hai bisogno di codici QR o a barre aggiuntivi, faccelo sapere!"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Se você precisa de códigos QR ou de barras adicionais, nos avise!"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Если вам нужны дополнительные QR-коды или штрих-коды, сообщите нам!"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Якщо вам потрібні додаткові QR-коди або штрих-коди, повідомте нас!"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Jeśli potrzebujesz dodatkowych kodów QR lub kreskowych, daj nam znać!"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Heeft u extra QR-codes of streepjescodes nodig? Laat het ons weten!"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Behöver du fler QR-koder eller streckkoder? Låt oss veta!"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "追加のQRコードやバーコードが必要な場合は、お知らせください！"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "추가 QR 코드 또는 바코드가 필요하시면 알려주세요!"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "如果您需要其他类型的二维码或条形码，请告诉我们！"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "如果您需要其他類型的QR碼或條碼，請告訴我們！"
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "หากคุณต้องการ QR โค้ดหรือบาร์โค้ดเพิ่มเติม แจ้งให้เราทราบ!"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "إذا كنت بحاجة إلى أنواع إضافية من رموز QR أو الباركود، أخبرنا!"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ek QR kod veya barkod türlerine ihtiyacınız varsa bize bildirin!"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "अगर आपको अतिरिक्त QR कोड या बारकोड प्रकार चाहिए, तो हमें बताएं!"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Nếu bạn cần thêm loại mã QR hoặc mã vạch, hãy cho chúng tôi biết!"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Jika Anda membutuhkan jenis kode QR atau barcode tambahan, beri tahu kami!"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Jika anda memerlukan kod QR atau kod bar tambahan, beritahu kami!"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Hvis du trenger flere QR-koder eller strekkoder, gi oss beskjed!"
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Hvis du har brug for flere QR-koder eller stregkoder, så lad os vide!"
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Jos tarvitset lisää QR-koodeja tai viivakoodeja, kerro meille!"
          }
        },
        "uz": {
          "stringUnit": {
            "state": "translated",
            "value": "Agar sizga qo'shimcha QR kodlar yoki shtrix-kodlar kerak bo'lsa, bizga xabar bering!"
          }
        }
      }
    },
