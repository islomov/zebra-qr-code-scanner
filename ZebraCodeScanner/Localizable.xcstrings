    "notification.body.barcode_scan_1" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "هل تريد التحقق من منتج؟ امسح الباركود الآن!"
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Har du brug for at tjekke et produkt? Scan stregkoden nu!"
