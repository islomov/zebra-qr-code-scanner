          "stringUnit": {
            "state": "translated",
            "value": "Skanning är för närvarande inte tillgänglig. Försök igen senare."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "スキャンは現在利用できません。後でもう一度お試しください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "현재 스캔을 사용할 수 없습니다. 나중에 다시 시도해 주세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "扫描功能暂不可用。请稍后再试。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "掃描功能暫時無法使用。請稍後再試。"
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "การสแกนไม่พร้อมใช้งานในขณะนี้ กรุณาลองอีกครั้งในภายหลัง"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "المسح غير متاح حالياً. يرجى المحاولة مرة أخرى لاحقاً."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tarama şu anda kullanılamıyor. Lütfen daha sonra tekrar deneyin."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "स्कैनिंग वर्तमान में अनुपलब्ध है। कृपया बाद में पुनः प्रयास करें।"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Chức năng quét hiện không khả dụng. Vui lòng thử lại sau."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Pemindaian saat ini tidak tersedia. Silakan coba lagi nanti."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Pengimbasan tidak tersedia buat masa ini. Sila cuba lagi kemudian."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Skanning er for øyeblikket utilgjengelig. Vennligst prøv igjen senere."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Scanning er i øjeblikket utilgængelig. Prøv venligst igen senere."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Skannaus ei ole tällä hetkellä käytettävissä. Yritä myöhemmin uudelleen."
          }
        },
        "uz": {
          "stringUnit": {
            "state": "translated",
            "value": "Skanlash hozircha mavjud emas. Iltimos, keyinroq qayta urinib ko'ring."
          }
        }
      }
