        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Consenti l'accesso alla fotocamera nelle Impostazioni per scansionare codici QR e a barre."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Permita o acesso à câmera nos Ajustes para escanear códigos QR e de barras."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Разрешите доступ к камере в Настройках для сканирования QR-кодов и штрих-кодов."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Дозвольте доступ до камери в Налаштуваннях для сканування QR-кодів та штрих-кодів."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zezwól na dostęp do aparatu w Ustawieniach, aby skanować kody QR i kreskowe."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Sta cameratoegang toe in Instellingen om QR-codes en streepjescodes te scannen."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Tillåt kameraåtkomst i Inställningar för att skanna QR-koder och streckkoder."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "QRコードやバーコードをスキャンするには、設定でカメラへのアクセスを許可してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "QR 코드와 바코드를 스캔하려면 설정에서 카메라 접근을 허용해 주세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "请在设置中允许相机访问以扫描二维码和条形码。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "請在設定中允許相機存取以掃描QR碼和條碼。"
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "กรุณาอนุญาตการเข้าถึงกล้องในการตั้งค่าเพื่อสแกน QR โค้ดและบาร์โค้ด"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يرجى السماح بالوصول إلى الكاميرا في الإعدادات لمسح رموز QR والباركود."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "QR kodları ve barkodları taramak için lütfen Ayarlar'dan kamera erişimine izin verin."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "QR कोड और बारकोड स्कैन करने के लिए कृपया सेटिंग्स में कैमरा एक्सेस की अनुमति दें।"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Vui lòng cho phép truy cập camera trong Cài đặt để quét mã QR và mã vạch."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Silakan izinkan akses kamera di Pengaturan untuk memindai kode QR dan barcode."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Sila benarkan akses kamera dalam Tetapan untuk mengimbas QR Code dan kod bar."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Vennligst tillat kameratilgang i Innstillinger for å skanne QR-koder og strekkoder."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Tillad venligst kameraadgang i Indstillinger for at scanne QR-koder og stregkoder."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Salli kameran käyttö Asetuksissa skannataksesi QR-koodeja ja viivakoodeja."
          }
        },
        "uz": {
          "stringUnit": {
            "state": "translated",
            "value": "QR kodlar va shtrix-kodlarni skanlash uchun Sozlamalarda kameraga ruxsat bering."
