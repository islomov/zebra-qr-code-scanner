        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Voer 7 of 8 cijfers in. Het controlecijfer wordt automatisch berekend"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Ange 7 eller 8 siffror. Kontrollsiffran beräknas automatiskt"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "7桁または8桁を入力してください。チェックディジットは自動計算されます"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "7자리 또는 8자리를 입력하세요. 체크 디지트가 자동으로 계산됩니다"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "请输入7位或8位数字。校验位将自动计算"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "請輸入7位或8位數字。檢查碼將自動計算"
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "กรอก 7 หรือ 8 หลัก ตัวเลขตรวจสอบจะคำนวณโดยอัตโนมัติ"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أدخل 7 أو 8 أرقام. سيتم حساب رقم التحقق تلقائياً"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "7 veya 8 rakam girin. Kontrol basamağı otomatik hesaplanır"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "7 या 8 अंक दर्ज करें। चेक डिजिट स्वचालित रूप से गणना होगी"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Nhập 7 hoặc 8 chữ số. Số kiểm tra sẽ được tính tự động"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Masukkan 7 atau 8 digit. Digit cek akan dihitung otomatis"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Masukkan 7 atau 8 digit. Digit semak akan dikira secara automatik"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Skriv inn 7 eller 8 sifre. Kontrollsifferet beregnes automatisk"
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Indtast 7 eller 8 cifre. Kontrolcifferet beregnes automatisk"
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Syötä 7 tai 8 numeroa. Tarkistusnumero lasketaan automaattisesti"
          }
        },
        "uz": {
          "stringUnit": {
            "state": "translated",
            "value": "7 yoki 8 ta raqam kiriting. Tekshiruv raqami avtomatik hisoblanadi"
          }
        }
      }
    },
