    "settings.language.restart_message": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Please restart the app for the language change to take effect."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Por favor, reinicia la app para que el cambio de idioma surta efecto."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Veuillez redémarrer l'application pour que le changement de langue prenne effet."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Bitte starten Sie die App neu, damit die Sprachänderung wirksam wird."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Riavvia l'app per applicare il cambio di lingua."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Por favor, reinicie o app para que a mudança de idioma tenha efeito."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Пожалуйста, перезапустите приложение, чтобы изменение языка вступило в силу."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Будь ласка, перезапустіть додаток, щоб зміна мови набула чинності."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Uruchom ponownie aplikację, aby zmiana języka została zastosowana."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Start de app opnieuw op om de taalwijziging toe te passen."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Starta om appen för att språkändringen ska träda i kraft."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "言語の変更を反映するには、アプリを再起動してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "언어 변경을 적용하려면 앱을 다시 시작해 주세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "请重新启动应用以使语言更改生效。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "請重新啟動應用程式以使語言變更生效。"
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "กรุณารีสตาร์ทแอปเพื่อให้การเปลี่ยนภาษามีผล"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يرجى إعادة تشغيل التطبيق لتفعيل تغيير اللغة."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Dil değişikliğinin geçerli olması için lütfen uygulamayı yeniden başlatın."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "भाषा परिवर्तन लागू करने के लिए कृपया ऐप को पुनरारंभ करें।"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Vui lòng khởi động lại ứng dụng để thay đổi ngôn ngữ có hiệu lực."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Silakan mulai ulang aplikasi agar perubahan bahasa diterapkan."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Sila mulakan semula aplikasi untuk perubahan bahasa berkuat kuasa."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Vennligst start appen på nytt for at språkendringen skal tre i kraft."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Genstart venligst appen for at sprogændringen træder i kraft."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Käynnistä sovellus uudelleen, jotta kielenvaihto tulee voimaan."
          }
        },
        "uz": {
          "stringUnit": {
            "state": "translated",
            "value": "Til o'zgarishi kuchga kirishi uchun ilovani qayta ishga tushiring."
          }
        }
      }
    }
  },
  "version": "1.1"
