    "history_detail.save_error": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Failed to save. Please check photo library permissions."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Error al guardar. Revisa los permisos de la biblioteca de fotos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Échec de l'enregistrement. Veuillez vérifier les autorisations de la photothèque."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Speichern fehlgeschlagen. Bitte überprüfe die Zugriffsrechte für die Fotomediathek."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Salvataggio non riuscito. Controlla i permessi della libreria foto."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Falha ao salvar. Verifique as permissões da biblioteca de fotos."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Не удалось сохранить. Проверьте разрешения для фотобиблиотеки."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Не вдалося зберегти. Перевірте дозволи для фотобібліотеки."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Nie udało się zapisać. Sprawdź uprawnienia do biblioteki zdjęć."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Opslaan mislukt. Controleer de machtigingen voor de fotobibliotheek."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Det gick inte att spara. Kontrollera behörigheterna för fotobiblioteket."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "保存に失敗しました。フォトライブラリの権限を確認してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "저장에 실패했습니다. 사진 라이브러리 권한을 확인해 주세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "保存失败。请检查相册访问权限。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "儲存失敗。請檢查相簿存取權限。"
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "บันทึกไม่สำเร็จ กรุณาตรวจสอบสิทธิ์การเข้าถึงคลังรูปภาพ"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "فشل الحفظ. يرجى التحقق من أذونات مكتبة الصور."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kaydetme başarısız. Lütfen fotoğraf kitaplığı izinlerini kontrol edin."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "सेव करना विफल रहा। कृपया फ़ोटो लाइब्रेरी अनुमतियाँ जांचें।"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Lưu thất bại. Vui lòng kiểm tra quyền truy cập thư viện ảnh."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Gagal menyimpan. Silakan periksa izin pustaka foto."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Gagal menyimpan. Sila semak kebenaran pustaka foto."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Kunne ikke lagre. Vennligst sjekk tillatelser for bildebiblioteket."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Kunne ikke gemme. Kontroller venligst tilladelser til fotobiblioteket."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tallennus epäonnistui. Tarkista kuvakirjaston käyttöoikeudet."
          }
        },
        "uz": {
          "stringUnit": {
            "state": "translated",
            "value": "Saqlab bo'lmadi. Foto kutubxona ruxsatlarini tekshiring."
          }
        }
      }
    },
