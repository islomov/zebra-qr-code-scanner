          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Не удалось сохранить QR-код. Проверьте разрешения для фотобиблиотеки."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Не вдалося зберегти QR-код. Перевірте дозволи для фотобібліотеки."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Nie udało się zapisać kodu QR. Sprawdź uprawnienia do biblioteki zdjęć."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Opslaan van QR-code mislukt. Controleer de machtigingen voor de fotobibliotheek."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Det gick inte att spara QR-koden. Kontrollera behörigheterna för fotobiblioteket."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "QRコードの保存に失敗しました。フォトライブラリの権限を確認してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "QR 코드 저장에 실패했습니다. 사진 라이브러리 권한을 확인해 주세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "二维码保存失败。请检查相册访问权限。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "QR碼儲存失敗。請檢查相簿存取權限。"
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "บันทึก QR โค้ดไม่สำเร็จ กรุณาตรวจสอบสิทธิ์การเข้าถึงคลังรูปภาพ"
          }
        },
        "ar": {
          "stringUnit": {
