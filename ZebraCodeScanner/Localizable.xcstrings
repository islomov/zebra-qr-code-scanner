    "scan.unsupported.message": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This device doesn't support barcode scanning. You can still import images from your photo library."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Este dispositivo no es compatible con el escaneo de códigos de barras. Aún puedes importar imágenes de tu biblioteca de fotos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cet appareil ne prend pas en charge le scan de codes-barres. Vous pouvez toujours importer des images depuis votre photothèque."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dieses Gerät unterstützt das Scannen von Barcodes nicht. Du kannst trotzdem Bilder aus deiner Fotomediathek importieren."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questo dispositivo non supporta la scansione dei codici a barre. Puoi comunque importare immagini dalla tua libreria foto."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Este dispositivo não suporta a leitura de códigos de barras. Você ainda pode importar imagens da sua biblioteca de fotos."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Это устройство не поддерживает сканирование штрих-кодов. Вы можете импортировать изображения из фотобиблиотеки."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Цей пристрій не підтримує сканування штрих-кодів. Ви можете імпортувати зображення з фотобібліотеки."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "To urządzenie nie obsługuje skanowania kodów kreskowych. Możesz importować obrazy z biblioteki zdjęć."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Dit apparaat ondersteunt het scannen van streepjescodes niet. U kunt afbeeldingen importeren uit uw fotobibliotheek."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Den här enheten stöder inte streckkodsläsning. Du kan fortfarande importera bilder från ditt fotobibliotek."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このデバイスはバーコードスキャンに対応していません。フォトライブラリから画像をインポートできます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 기기는 바코드 스캔을 지원하지 않습니다. 사진 라이브러리에서 이미지를 가져올 수 있습니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此设备不支持条形码扫描。您仍可以从相册导入图片。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "此裝置不支援條碼掃描。您仍可以從相簿匯入圖片。"
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "อุปกรณ์นี้ไม่รองรับการสแกนบาร์โค้ด คุณยังสามารถนำเข้ารูปภาพจากคลังรูปภาพได้"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "هذا الجهاز لا يدعم مسح الباركود. لا يزال بإمكانك استيراد الصور من مكتبة الصور."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu cihaz barkod taramayı desteklemiyor. Yine de fotoğraf kitaplığınızdan görsel içe aktarabilirsiniz."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "यह डिवाइस बारकोड स्कैनिंग सपोर्ट नहीं करता। आप अभी भी अपनी फ़ोटो लाइब्रेरी से इमेज इंपोर्ट कर सकते हैं।"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Thiết bị này không hỗ trợ quét mã vạch. Bạn vẫn có thể nhập ảnh từ thư viện ảnh."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Perangkat ini tidak mendukung pemindaian barcode. Anda masih dapat mengimpor gambar dari pustaka foto."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Peranti ini tidak menyokong pengimbasan kod bar. Anda masih boleh mengimport imej daripada pustaka foto anda."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Denne enheten støtter ikke strekkodeskanning. Du kan fortsatt importere bilder fra bildebiblioteket ditt."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Denne enhed understøtter ikke stregkodescanning. Du kan stadig importere billeder fra dit fotobibliotek."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tämä laite ei tue viivakoodien skannausta. Voit silti tuoda kuvia kuvakirjastostasi."
          }
        },
        "uz": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu qurilma shtrix-kod skanlashni qo'llab-quvvatlamaydi. Siz hali ham foto kutubxonangizdan rasmlarni import qilishingiz mumkin."
          }
        }
      }
    },
