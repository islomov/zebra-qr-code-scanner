        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Inserisci 11 o 12 cifre. La cifra di controllo verrà calcolata automaticamente"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Digite 11 ou 12 dígitos. O dígito verificador será calculado automaticamente"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Введите 11 или 12 цифр. Контрольная цифра будет рассчитана автоматически"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Введіть 11 або 12 цифр. Контрольна цифра буде розрахована автоматично"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wpisz 11 lub 12 cyfr. Cyfra kontrolna zostanie obliczona automatycznie"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Voer 11 of 12 cijfers in. Het controlecijfer wordt automatisch berekend"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Ange 11 eller 12 siffror. Kontrollsiffran beräknas automatiskt"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "11桁または12桁を入力してください。チェックディジットは自動計算されます"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "11자리 또는 12자리를 입력하세요. 체크 디지트가 자동으로 계산됩니다"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "请输入11位或12位数字。校验位将自动计算"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "請輸入11位或12位數字。檢查碼將自動計算"
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "กรอก 11 หรือ 12 หลัก ตัวเลขตรวจสอบจะคำนวณโดยอัตโนมัติ"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أدخل 11 أو 12 رقماً. سيتم حساب رقم التحقق تلقائياً"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "11 veya 12 rakam girin. Kontrol basamağı otomatik hesaplanır"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "11 या 12 अंक दर्ज करें। चेक डिजिट स्वचालित रूप से गणना होगी"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Nhập 11 hoặc 12 chữ số. Số kiểm tra sẽ được tính tự động"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Masukkan 11 atau 12 digit. Digit cek akan dihitung otomatis"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Masukkan 11 atau 12 digit. Digit semak akan dikira secara automatik"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Skriv inn 11 eller 12 sifre. Kontrollsifferet beregnes automatisk"
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Indtast 11 eller 12 cifre. Kontrolcifferet beregnes automatisk"
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Syötä 11 tai 12 numeroa. Tarkistusnumero lasketaan automaattisesti"
          }
        },
        "uz": {
          "stringUnit": {
            "state": "translated",
            "value": "11 yoki 12 ta raqam kiriting. Tekshiruv raqami avtomatik hisoblanadi"
          }
        }
      }
