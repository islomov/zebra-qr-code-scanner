    "scan.permission.message": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Please allow camera access in Settings to scan QR codes and barcodes."
          }
        },
        "es": {
          "stringUnit": {
